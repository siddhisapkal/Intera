# ── GraphMind Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphmind123

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
REDIS_URL=redis://redis:6379

# ── AI Models — at least one of Gemini or Groq is required ───────────────────
# Google Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fast inference, optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
# Secret key for session signing (change this!)
SECRET_KEY=change_me_to_a_random_secret

# ── FAISS index storage ───────────────────────────────────────────────────────
FAISS_INDEX_DIR=/app/faiss_indexes
